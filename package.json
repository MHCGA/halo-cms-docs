{
  "name": "halo-cms-docs",
  "version": "1.0.0",
  "private": true,
  "description": "Share tips related to Halo CMS.",
  "keywords": [
    "halo"
  ],
  "homepage": "https://github.com/MHCGA",
  "license": "MIT",
  "author": "MHCGA",
  "repository": {
    "type": "git",
    "url": "https://github.com/MHCGA/halo-cms-docs"
  },
  "type": "module",
  "scripts": {
    "build": "pnpm run \"/:build$/\"",
    "docs:build": "vitepress build docs",
    "docs:preview": "pnpm run docs:build && vitepress preview docs",
    "docs:watch": "vitepress dev docs",
    "fmt": "pnpm run \"/^fmt:/\"",
    "fmt:oxfmt": "oxfmt --threads 2 \"**/*.{json,jsonc,yaml,md,css,js,ts,vue,html}\" \".github/**/*.{yml,js,json}\"",
    "lint": "pnpm run \"/^lint:/\"",
    "lint:autocorrect": "autocorrect --fix",
    "lint:md": "markdownlint --fix \"**/*.md\" --ignore-path .gitignore",
    "lint:oxlint+eslint": "oxlint --type-aware --fix && eslint --fix",
    "lint:style": "stylelint --fix \"**/*.{css,vue}\" \"docs/.vitepress/**/*.{css,vue}\" --ignore-path .gitignore",
    "migrate:oxlint": "pnpm dlx @oxlint/migrate --type-aware --with-nursery && pnpm run fmt",
    "preinstall": "npx only-allow pnpm",
    "watch": "pnpm run \"/:watch$/\""
  },
  "devDependencies": {
    "@eslint/compat": "^2.1.0",
    "@eslint/js": "^10.0.1",
    "@giscus/vue": "^3.1.1",
    "@nolebase/vitepress-plugin-highlight-targeted-heading": "^2.18.2",
    "@types/node": "^25.9.1",
    "@typescript-eslint/parser": "^8.60.1",
    "autocorrect-node": "^2.14.0",
    "browserslist": "^4.28.2",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-oxlint": "^1.68.0",
    "eslint-plugin-vue": "^10.9.1",
    "globals": "^17.6.0",
    "lightningcss": "^1.32.0",
    "markdownlint-cli": "^0.48.0",
    "oxfmt": "^0.53.0",
    "oxlint": "^1.68.0",
    "oxlint-tsgolint": "^0.23.0",
    "pagefind": "^1.5.2",
    "stylelint": "^17.12.0",
    "stylelint-config-html": "^1.1.0",
    "stylelint-config-recommended-vue": "^1.6.1",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-order": "^8.1.1",
    "typescript-eslint": "^8.60.1",
    "vitepress": "2.0.0-alpha.17",
    "vitepress-plugin-pagefind": "^0.4.20",
    "vitepress-plugin-rss": "^0.4.4",
    "vue": "^3.5.35",
    "vue-eslint-parser": "^10.4.1"
  },
  "overrides": {
    "vite": "npm:rolldown-vite@^7.3.1"
  },
  "browserslist": [
    "defaults",
    "Safari >= 16.4",
    "Chrome >= 111",
    "Firefox >= 128"
  ],
  "engines": {
    "node": ">=24",
    "pnpm": "^11.5.0"
  },
  "packageManager": "pnpm@11.5.0"
}
